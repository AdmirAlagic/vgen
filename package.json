{
  "name": "vgenerator-audio-visualizer",
  "version": "2.0.0",
  "description": "Professional audio visualizer with hybrid web/Python architecture - generates high-quality MP4 videos using Mac FFmpeg",
  "main": "index.html",
  "scripts": {
    "setup": "./setup.sh",
    "start": "python3 -m http.server 8000",
    "generate": "./run.sh",
    "serve": "python3 -m http.server 8000"
  },
  "keywords": [
    "audio",
    "visualizer",
    "music",
    "visualization",
    "video",
    "recording",
    "youtube",
    "web-audio",
    "canvas",
    "real-time"
  ],
  "author": "VGenerator Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/vgenerator-audio-visualizer"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "devDependencies": {},
  "dependencies": {},
  "features": {
    "audioFormats": ["MP3", "WAV", "OGG", "M4A", "FLAC"],
    "visualizations": [
      "Spectrum Analyzer",
      "Waveform",
      "Circular Spectrum",
      "Particle System",
      "3D Bars"
    ],
    "colorSchemes": [
      "Neon",
      "Fire",
      "Ocean",
      "Sunset", 
      "Monochrome",
      "Rainbow"
    ],
    "videoQualities": ["720p", "1080p", "4K"],
    "videoFormats": ["WebM (VP9)", "WebM (VP8)", "MP4"],
    "audioCodecs": ["Opus", "Vorbis", "AAC"],
    "effects": [
      "Glow Effect",
      "Motion Blur",
      "Particle Overlay",
      "Beat Detection",
      "Real-time Analysis"
    ]
  },
  "requirements": {
    "browser": {
      "webAudio": "Required for audio analysis",
      "canvas": "Required for visualization rendering",
      "mediaRecorder": "Required for video recording",
      "captureStream": "Required for canvas recording"
    },
    "permissions": {
      "microphone": "Optional - for real-time audio input",
      "camera": "Not required"
    }
  },
  "performance": {
    "fps": "60fps rendering",
    "audioLatency": "<10ms",
    "videoEncoding": "Hardware accelerated when available"
  }
}