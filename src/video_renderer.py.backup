"""
Video Renderer Module

Handles Blender rendering and video export with audio merging.
"""

import subprocess
import os
import shutil
from pathlib import Path
from typing import Dict, Callable, Optional


class VideoRenderer:
    """Renders Blender scenes and exports videos with audio."""
    
    def __init__(self, blender_path: str = None):
        """
        Initialize video renderer.
        
        Args:
            blender_path: Path to Blender executable (auto-detected if None)
        """
        self.blender_path = blender_path or self._find_blender()
        if not self.blender_path:
            raise RuntimeError("Blender not found. Please install Blender or specify path.")
        
        print(f"✅ Using Blender: {self.blender_path}")
        
    def _find_blender(self) -> Optional[str]:
        """Auto-detect Blender installation on macOS."""
        possible_paths = [
            "/Applications/Blender.app/Contents/MacOS/Blender",
            "/Applications/Blender 4.0/Blender.app/Contents/MacOS/Blender",
            "/Applications/Blender 3.6/Blender.app/Contents/MacOS/Blender",
            "/Applications/Blender 4.1/Blender.app/Contents/MacOS/Blender",
            "/Applications/Blender 4.2/Blender.app/Contents/MacOS/Blender",
            str(Path.home() / "Applications" / "Blender.app" / "Contents" / "MacOS" / "Blender"),
        ]
        
        # Check if blender is in PATH
        if shutil.which("blender"):
            return "blender"
        
        # Check common installation paths
        for path in possible_paths:
            if os.path.exists(path):
                return path
        
        return None
    
    def run_blender_script(
        self, 
        script_path: str, 
        output_dir: str,
        progress_callback: Callable[[int, str], None] = None
    ) -> str:
        """
        Execute Blender script to generate scene.
        
        Args:
            script_path: Path to Blender Python script
            output_dir: Directory for output files
            progress_callback: Function to call with progress updates
            
        Returns:
            Path to generated .blend file
        """
        print("🎨 Running Blender script...")
        
        if progress_callback:
            progress_callback(10, "Executing Blender script...")
        
        # Run Blender in background mode
        cmd = [
            self.blender_path,
            "--background",
            "--python", script_path
        ]
        
        try:
            result = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                check=True
            )
            
            print("✅ Blender script executed successfully")
            if progress_callback:
                progress_callback(30, "Scene created successfully")
            
            # Find the generated .blend file
            blend_file = os.path.join(output_dir, "scene.blend")
            if os.path.exists(blend_file):
                return blend_file
            
            # Look for .blend files in output directory
            blend_files = list(Path(output_dir).glob("*.blend"))
            if blend_files:
                return str(blend_files[0])
            
            raise RuntimeError("No .blend file found after script execution")
            
        except subprocess.CalledProcessError as e:
            print(f"❌ Blender script failed:")
            print(e.stderr)
            raise RuntimeError(f"Blender script execution failed: {e.stderr}")
    
    def render_animation(
        self,
        blend_file: str,
        output_dir: str,
        progress_callback: Callable[[int, str], None] = None
    ) -> str:
        """
        Render animation from Blender file.
        
        Args:
            blend_file: Path to .blend file
            output_dir: Directory for rendered frames
            progress_callback: Function for progress updates
            
        Returns:
            Path to rendered frames directory
        """
        print("🎬 Rendering animation...")
        
        if progress_callback:
            progress_callback(40, "Starting render...")
        
        frames_dir = os.path.join(output_dir, "frames")
        os.makedirs(frames_dir, exist_ok=True)
        
        # Render command
        cmd = [
            self.blender_path,
            "--background",
            blend_file,
            "--render-output", os.path.join(frames_dir, "frame_####"),
            "--render-format", "PNG",
            "--render-anim"
        ]
        
        try:
            # Run rendering with progress monitoring
            process = subprocess.Popen(
                cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1
            )
            
            frame_count = 0
            for line in process.stdout:
                print(line.strip())
                
                # Parse frame progress
                if "Fra:" in line:
                    try:
                        frame_num = int(line.split("Fra:")[1].split()[0])
                        # Estimate progress (40% to 90%)
                        progress = 40 + int((frame_num / 100) * 50)
                        if progress_callback:
                            progress_callback(
                                min(progress, 90),
                                f"Rendering frame {frame_num}..."
                            )
                        frame_count = frame_num
                    except:
                        pass
            
            process.wait()
            
            if process.returncode != 0:
                raise RuntimeError("Rendering failed")
            
            print(f"✅ Rendered {frame_count} frames")
            if progress_callback:
                progress_callback(90, f"Rendering complete ({frame_count} frames)")
            
            return frames_dir
            
        except Exception as e:
            print(f"❌ Rendering failed: {e}")
            raise RuntimeError(f"Rendering failed: {e}")
    
    def merge_with_audio(
        self,
        frames_dir: str,
        audio_path: str,
        output_path: str,
        fps: int = 60,
        progress_callback: Callable[[int, str], None] = None
    ) -> str:
        """
        Merge rendered frames with audio using FFmpeg.
        
        Args:
            frames_dir: Directory containing rendered frames
            audio_path: Path to audio file
            output_path: Path for output video
            fps: Frames per second
            progress_callback: Function for progress updates
            
        Returns:
            Path to final video file
        """
        print("🎵 Merging video with audio...")
        
        if progress_callback:
            progress_callback(92, "Merging audio and video...")
        
        # Check if ffmpeg is available
        if not shutil.which("ffmpeg"):
            raise RuntimeError(
                "FFmpeg not found. Please install: brew install ffmpeg"
            )
        
        # FFmpeg command for high-quality YouTube video
        cmd = [
            "ffmpeg",
            "-y",  # Overwrite output file
            "-framerate", str(fps),
            "-i", os.path.join(frames_dir, "frame_%04d.png"),
            "-i", audio_path,
            "-c:v", "libx264",  # H.264 codec
            "-preset", "slow",  # Better compression
            "-crf", "18",  # High quality (lower = better, 18 is visually lossless)
            "-pix_fmt", "yuv420p",  # Compatibility
            "-c:a", "aac",  # AAC audio codec
            "-b:a", "320k",  # High audio bitrate
            "-shortest",  # Match video length to audio
            "-movflags", "+faststart",  # Web optimization
            output_path
        ]
        
        try:
            result = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                check=True
            )
            
            print(f"✅ Video saved to {output_path}")
            if progress_callback:
                progress_callback(100, "Video generation complete!")
            
            # Get file size
            size_mb = os.path.getsize(output_path) / (1024 * 1024)
            print(f"📁 File size: {size_mb:.2f} MB")
            
            return output_path
            
        except subprocess.CalledProcessError as e:
            print(f"❌ FFmpeg failed:")
            print(e.stderr)
            raise RuntimeError(f"Video merge failed: {e.stderr}")
    
    def generate_video(
        self,
        script_path: str,
        audio_path: str,
        output_path: str,
        fps: int = 60,
        progress_callback: Callable[[int, str], None] = None,
        keep_temp_files: bool = False
    ) -> str:
        """
        Complete video generation pipeline (traditional method with PNG frames).
        
        Args:
            script_path: Path to Blender script
            audio_path: Path to audio file
            output_path: Path for final video
            fps: Frames per second
            progress_callback: Progress callback function
            keep_temp_files: Keep temporary files if True
            
        Returns:
            Path to generated video
        """
        temp_dir = os.path.join(os.path.dirname(output_path), "temp")
        os.makedirs(temp_dir, exist_ok=True)
        
        try:
            # Step 1: Run Blender script
            blend_file = self.run_blender_script(script_path, temp_dir, progress_callback)
            
            # Step 2: Render animation
            frames_dir = self.render_animation(blend_file, temp_dir, progress_callback)
            
            # Step 3: Merge with audio
            final_video = self.merge_with_audio(
                frames_dir, audio_path, output_path, fps, progress_callback
            )
            
            # Cleanup temporary files
            if not keep_temp_files:
                print("🧹 Cleaning up temporary files...")
                shutil.rmtree(temp_dir, ignore_errors=True)
            
            return final_video
            
        except Exception as e:
            print(f"❌ Video generation failed: {e}")
            raise
    
    def generate_video_direct(
        self,
        script_path: str,
        audio_path: str,
        output_path: str,
        fps: int = 60,
        progress_callback: Callable[[int, str], None] = None
    ) -> str:
        """
        Robust video generation with multiple fallback strategies.
        
        This method tries multiple approaches in order:
        1. Blender direct video render with FFmpeg
        2. PNG sequence render + FFmpeg merge
        3. PNG sequence render + manual FFmpeg with audio
        4. Alternative codecs if H.264 fails
        
        Args:
            script_path: Path to Blender script
            audio_path: Path to audio file
            output_path: Path for final video
            fps: Frames per second
            progress_callback: Progress callback function
            
        Returns:
            Path to generated video
        """
        print("🚀 Starting robust video generation with fallback strategies...")
        
        if progress_callback:
            progress_callback(5, "Initializing video generation...")
        
        # Strategy 1: Try direct video render first
        try:
            print("🎯 Strategy 1: Attempting direct video render...")
            video_path = self._try_direct_video_render(
                script_path, output_path, fps, progress_callback
            )
            if video_path and os.path.exists(video_path):
                # Merge with audio
                final_path = self._merge_video_with_audio(
                    video_path, audio_path, output_path, progress_callback
                )
                if final_path:
                    return final_path
        except Exception as e:
            print(f"⚠️ Direct video render failed: {e}")
        
        # Strategy 2: PNG sequence + FFmpeg
        try:
            print("🎯 Strategy 2: Using PNG sequence + FFmpeg...")
            return self.generate_video_sequence_method(
                script_path, audio_path, output_path, fps, progress_callback
            )
        except Exception as e:
            print(f"⚠️ PNG sequence method failed: {e}")
        
        # Strategy 3: Alternative codec fallback
        try:
            print("🎯 Strategy 3: Trying alternative codecs...")
            return self._try_alternative_codecs(
                script_path, audio_path, output_path, fps, progress_callback
            )
        except Exception as e:
            print(f"⚠️ Alternative codecs failed: {e}")
        
        # If all strategies fail, raise error
        raise RuntimeError(
            "All video generation strategies failed. "
            "Please check Blender installation and FFmpeg availability."
        )
    
    def _try_direct_video_render(
        self,
        script_path: str,
        output_path: str,
        fps: int,
        progress_callback: Callable[[int, str], None] = None
    ) -> Optional[str]:
        """Try direct video rendering from Blender."""
        if progress_callback:
            progress_callback(10, "Running Blender with direct video output...")
        
        # Create temporary script for direct video rendering
        temp_script_path = script_path.replace('.py', '_direct.py')
        self._create_direct_video_script(script_path, temp_script_path, output_path)
        
        try:
            cmd = [
                self.blender_path,
                "--background",
                "--python", temp_script_path
            ]
            
            result = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                check=True,
                timeout=300  # 5 minute timeout
            )
            
            print("✅ Blender direct render completed")
            if progress_callback:
                progress_callback(60, "Direct video render completed")
            
            # Check if video was created
            if os.path.exists(output_path):
                size_mb = os.path.getsize(output_path) / (1024 * 1024)
                print(f"✅ Direct video created: {size_mb:.2f} MB")
                return output_path
            
            # Try with .mp4 extension if not found
            mp4_path = output_path.replace('.mp4', '_temp.mp4')
            if os.path.exists(mp4_path):
                os.rename(mp4_path, output_path)
                return output_path
                
            return None
            
        except subprocess.TimeoutExpired:
            print("⚠️ Direct render timed out")
            return None
        except Exception as e:
            print(f"⚠️ Direct render failed: {e}")
            return None
        finally:
            # Clean up temporary script
            if os.path.exists(temp_script_path):
                os.remove(temp_script_path)
    
    def _create_direct_video_script(
        self,
        original_script_path: str,
        output_script_path: str,
        video_output_path: str
    ):
        """Create a modified script for direct video rendering."""
        with open(original_script_path, 'r') as f:
            script_content = f.read()
        
        # Modify the script to use direct video output
        modified_content = script_content.replace(
            "scene.render.image_settings.file_format = 'FFMPEG'",
            '''# Direct video output settings
scene.render.image_settings.file_format = 'FFMPEG'
scene.render.ffmpeg.format = 'MPEG4'
scene.render.ffmpeg.codec = 'H264'
scene.render.ffmpeg.constant_rate_factor = 'HIGH'
scene.render.ffmpeg.ffmpeg_preset = 'GOOD'
scene.render.filepath = "{}"'''.format(video_output_path)
        )
        
        # Ensure the render command is present
        if "bpy.ops.render.render(animation=True)" not in modified_content:
            modified_content += "\n# Render animation\nbpy.ops.render.render(animation=True)\n"
        
        with open(output_script_path, 'w') as f:
            f.write(modified_content)
    
    def generate_video_sequence_method(
        self,
        script_path: str,
        audio_path: str,
        output_path: str,
        fps: int = 60,
        progress_callback: Callable[[int, str], None] = None
    ) -> str:
        """
        Generate video using PNG sequence method (most reliable).
        
        This is the fallback method that renders to PNG frames first,
        then uses FFmpeg to create the final video with audio.
        """
        print("📁 Using PNG sequence method...")
        
        temp_dir = os.path.join(os.path.dirname(output_path), "temp")
        os.makedirs(temp_dir, exist_ok=True)
        
        try:
            # Step 1: Create script for PNG rendering
            png_script_path = script_path.replace('.py', '_png.py')
            self._create_png_sequence_script(script_path, png_script_path, temp_dir)
            
            # Step 2: Run Blender script to generate PNG frames
            if progress_callback:
                progress_callback(20, "Rendering PNG frames...")
            
            blend_file = self.run_blender_script(png_script_path, temp_dir, progress_callback)
            
            # Step 3: Render animation to PNG frames
            frames_dir = self.render_animation(blend_file, temp_dir, progress_callback)
            
            # Step 4: Create video from frames with audio
            final_video = self._create_video_from_frames_with_audio(
                frames_dir, audio_path, output_path, fps, progress_callback
            )
            
            # Cleanup
            if os.path.exists(png_script_path):
                os.remove(png_script_path)
            
            return final_video
            
        except Exception as e:
            print(f"❌ PNG sequence method failed: {e}")
            raise
    
    def _create_png_sequence_script(
        self,
        original_script_path: str,
        output_script_path: str,
        temp_dir: str
    ):
        """Create a script that renders to PNG sequence instead of video."""
        with open(original_script_path, 'r') as f:
            script_content = f.read()
        
        # Replace video output settings with PNG settings
        modified_content = script_content.replace(
            "scene.render.image_settings.file_format = 'FFMPEG'",
            '''# PNG sequence output settings
scene.render.image_settings.file_format = 'PNG'
scene.render.image_settings.color_mode = 'RGBA'
scene.render.filepath = os.path.join("{}", "frame_####")'''.format(temp_dir)
        )
        
        # Remove direct video render and replace with blend save
        modified_content = modified_content.replace(
            "# Render directly to video\nprint(\"Starting direct video render...\")\nbpy.ops.render.render(animation=True)",
            '''# Save blend file for rendering
bpy.ops.wm.save_as_mainfile(filepath=os.path.join("{}", "scene.blend"))'''.format(temp_dir)
        )
        
        with open(output_script_path, 'w') as f:
            f.write(modified_content)
    
    def _create_video_from_frames_with_audio(
        self,
        frames_dir: str,
        audio_path: str,
        output_path: str,
        fps: int,
        progress_callback: Callable[[int, str], None] = None
    ) -> str:
        """Create video from PNG frames with audio using FFmpeg."""
        print("🎵 Creating video from frames with audio...")
        
        if progress_callback:
            progress_callback(85, "Merging frames and audio...")
        
        # Check if FFmpeg is available
        if not shutil.which("ffmpeg"):
            raise RuntimeError("FFmpeg not found. Please install: brew install ffmpeg")
        
        # Count frames
        frame_files = list(Path(frames_dir).glob("frame_*.png"))
        if not frame_files:
            raise RuntimeError("No PNG frames found")
        
        print(f"📊 Found {len(frame_files)} frames")
        
        # FFmpeg command for high-quality video with audio
        cmd = [
            "ffmpeg",
            "-y",  # Overwrite output file
            "-framerate", str(fps),
            "-i", os.path.join(frames_dir, "frame_%04d.png"),
            "-i", audio_path,
            "-c:v", "libx264",  # H.264 video codec
            "-preset", "medium",  # Balance between speed and quality
            "-crf", "18",  # High quality (18 is visually lossless)
            "-pix_fmt", "yuv420p",  # Compatibility
            "-c:a", "aac",  # AAC audio codec
            "-b:a", "320k",  # High audio bitrate
            "-shortest",  # Match video length to audio
            "-movflags", "+faststart",  # Web optimization
            "-vf", "scale=1920:1080",  # Ensure proper resolution
            output_path
        ]
        
        try:
            result = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                check=True,
                timeout=600  # 10 minute timeout
            )
            
            print(f"✅ Video created successfully: {output_path}")
            
            # Get file size
            size_mb = os.path.getsize(output_path) / (1024 * 1024)
            print(f"📁 Final file size: {size_mb:.2f} MB")
                
                if progress_callback:
                    progress_callback(100, "Video generation complete!")
                
                return output_path
                
        except subprocess.TimeoutExpired:
            raise RuntimeError("FFmpeg timed out while creating video")
        except subprocess.CalledProcessError as e:
            print(f"❌ FFmpeg failed:")
            print(e.stderr)
            raise RuntimeError(f"Video creation failed: {e.stderr}")
    
    def _merge_video_with_audio(
        self,
        video_path: str,
        audio_path: str,
        output_path: str,
        progress_callback: Callable[[int, str], None] = None
    ) -> Optional[str]:
        """Merge video with audio using FFmpeg."""
        if progress_callback:
            progress_callback(70, "Merging video with audio...")
        
        if not shutil.which("ffmpeg"):
            print("⚠️ FFmpeg not available for audio merge")
            return video_path
        
        try:
            cmd = [
                "ffmpeg",
                "-y",
                "-i", video_path,
                "-i", audio_path,
                "-c:v", "copy",  # Copy video without re-encoding
                "-c:a", "aac",   # Re-encode audio
                "-b:a", "320k",
                "-shortest",     # Match shorter duration
                output_path
            ]
            
            result = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                check=True,
                timeout=120
            )
            
            # Remove original video without audio
            if video_path != output_path:
                os.remove(video_path)
            
            return output_path
            
        except Exception as e:
            print(f"⚠️ Audio merge failed: {e}")
            return video_path  # Return video without audio
    
    def _try_alternative_codecs(
        self,
        script_path: str,
        audio_path: str,
        output_path: str,
        fps: int,
        progress_callback: Callable[[int, str], None] = None
    ) -> str:
        """Try alternative video codecs if H.264 fails."""
        print("🎯 Trying alternative codecs...")
        
        # Try different codec combinations
        codec_configs = [
            {"codec": "libx264", "preset": "fast", "crf": "23"},
            {"codec": "libx264", "preset": "ultrafast", "crf": "28"},
            {"codec": "libx265", "preset": "medium", "crf": "20"},
            {"codec": "mpeg4", "qscale": "2"}
        ]
        
        for config in codec_configs:
            try:
                print(f"🔄 Trying {config['codec']} codec...")
                
                # Use PNG sequence method with alternative codec
                temp_dir = os.path.join(os.path.dirname(output_path), "temp")
                frames_dir = os.path.join(temp_dir, "frames")
                
                if not os.path.exists(frames_dir):
                    # Need to render frames first
                    png_script_path = script_path.replace('.py', '_png.py')
                    self._create_png_sequence_script(script_path, png_script_path, temp_dir)
                    blend_file = self.run_blender_script(png_script_path, temp_dir, progress_callback)
                    self.render_animation(blend_file, temp_dir, progress_callback)
                
                # Create video with alternative codec
                final_video = self._create_video_with_codec(
                    frames_dir, audio_path, output_path, fps, config, progress_callback
                )
                
                if final_video and os.path.exists(final_video):
                    return final_video
                    
            except Exception as e:
                print(f"⚠️ {config['codec']} failed: {e}")
                continue
        
        raise RuntimeError("All codec alternatives failed")
    
    def _create_video_with_codec(
        self,
        frames_dir: str,
        audio_path: str,
        output_path: str,
        fps: int,
        codec_config: dict,
        progress_callback: Callable[[int, str], None] = None
    ) -> str:
        """Create video with specific codec configuration."""
        cmd = [
            "ffmpeg",
            "-y",
            "-framerate", str(fps),
            "-i", os.path.join(frames_dir, "frame_%04d.png"),
            "-i", audio_path,
            "-c:v", codec_config["codec"],
            "-c:a", "aac",
            "-b:a", "320k",
            "-shortest",
            "-movflags", "+faststart"
        ]
        
        # Add codec-specific parameters
        if "preset" in codec_config:
            cmd.extend(["-preset", codec_config["preset"]])
        if "crf" in codec_config:
            cmd.extend(["-crf", codec_config["crf"]])
        if "qscale" in codec_config:
            cmd.extend(["-qscale:v", codec_config["qscale"]])
        
        cmd.append(output_path)
        
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            check=True,
            timeout=600
        )
        
        return output_path
    
    def generate_video_optimized(
        self,
        script_path: str,
        audio_path: str,
        output_path: str,
        fps: int = 60,
        progress_callback: Callable[[int, str], None] = None,
        use_direct_render: bool = True
    ) -> str:
        """
        Smart video generation with robust fallback strategies.
        
        This method automatically tries multiple approaches to ensure
        video generation succeeds:
        1. Direct video render (fastest)
        2. PNG sequence + FFmpeg (most reliable)
        3. Alternative codecs (fallback)
        
        Args:
            script_path: Path to Blender script
            audio_path: Path to audio file
            output_path: Path for final video
            fps: Frames per second
            progress_callback: Progress callback function
            use_direct_render: Use direct video rendering if True (recommended)
            
        Returns:
            Path to generated video
        """
        if use_direct_render:
            print("🎯 Using robust video generation with fallback strategies...")
            return self.generate_video_direct(
                script_path, audio_path, output_path, fps, progress_callback
            )
        else:
            print("📁 Using traditional PNG frame generation...")
            return self.generate_video(
                script_path, audio_path, output_path, fps, progress_callback
            )


if __name__ == "__main__":
    # Test the renderer
    import sys
    
    if len(sys.argv) > 2:
        renderer = VideoRenderer()
        renderer.generate_video(
            script_path=sys.argv[1],
            audio_path=sys.argv[2],
            output_path="test_output.mp4"
        )
    else:
        print("Usage: python video_renderer.py <blender_script.py> <audio_file>")
